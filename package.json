{
  "name": "@gonzih/cc-agent",
  "version": "0.2.3",
  "description": "MCP server for spawning Claude Code agents in cloned repos — branch your agents",
  "type": "module",
  "bin": {
    "cc-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Gonzih/cc-agent.git"
  },
  "homepage": "https://github.com/Gonzih/cc-agent",
  "bugs": {
    "url": "https://github.com/Gonzih/cc-agent/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "agent",
    "ai",
    "model-context-protocol",
    "branching-agents"
  ],
  "license": "MIT"
}
